{
  "entities": {
    "waitlist": {
      "title": "Waitlist Lead",
      "description": "A lead in the waitlist with referral information",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "whatsapp": {
          "type": "string",
          "description": "User's WhatsApp number"
        },
        "rank": {
          "type": "integer",
          "description": "Current position in the waitlist"
        },
        "referralCode": {
          "type": "string",
          "description": "Unique code for referrals"
        },
        "referredBy": {
          "type": "string",
          "description": "The referralCode of the user who referred this lead"
        },
        "referralCount": {
          "type": "integer",
          "description": "Number of people referred by this user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the lead joined"
        },
        "ip": {
          "type": "string",
          "description": "IP address of the user"
        }
      },
      "required": ["email", "whatsapp", "rank", "referralCode", "createdAt"]
    },
    "stats": {
      "title": "Stats",
      "description": "Global statistics for the application.",
      "type": "object",
      "properties": {
        "waitlistCount": {
          "type": "integer",
          "description": "Total number of users in the waitlist."
        }
      }
    }
  },
  "firestore": {
    "/waitlist/{entryId}": {
      "schema": "waitlist",
      "description": "Collection of waitlist entries."
    },
    "/stats/global": {
      "schema": "stats",
      "description": "Global statistics document."
    }
  }
}
